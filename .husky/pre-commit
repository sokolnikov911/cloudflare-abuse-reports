#!/usr/bin/env sh

REQUIRED_PHP="8.1"
CURRENT_PHP=$(php -r "echo PHP_MAJOR_VERSION.'.'.PHP_MINOR_VERSION;")

if [ "$(printf '%s\n' "$REQUIRED_PHP" "$CURRENT_PHP" | sort -V | head -n1)" != "$REQUIRED_PHP" ]; then
    echo "Pre-commit hook requires PHP >= $REQUIRED_PHP (found $CURRENT_PHP). Update your PATH."
    exit 1
fi

echo "Running composer audit..."
composer audit

echo "Running PHPStan..."
vendor/bin/phpstan analyse --no-progress

echo "Running PHP CodeSniffer..."
vendor/bin/phpcs

echo "Running PHPUnit..."
vendor/bin/phpunit --no-coverage
