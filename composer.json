{
    "name": "sokolnikov911/cloudflare-abuse-reports",
    "description": "PHP client for the Cloudflare Abuse Reports API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "CloudflareAbuse\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CloudflareAbuse\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^10.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --no-progress",
        "cs": "phpcs",
        "cs-fix": "phpcbf",
        "check": [
            "@test",
            "@analyse",
            "@cs"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
